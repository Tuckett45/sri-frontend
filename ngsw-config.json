{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "assetGroups": [
    {
      "name": "app",
      "installMode": "prefetch",
      "resources": {
        "files": [
          "/favicon.ico",
          "/index.html",
          "/*.css",
          "/*.js"
        ]
      }
    },
    {
      "name": "assets",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/assets/**",
          "/*.(svg|cur|jpg|jpeg|png|apng|webp|avif|gif|otf|ttf|woff|woff2)"
        ]
      }
    }
  ],
  "dataGroups": [
    {
      "name": "api-cache",
      "urls": [
        "/api/**"
      ],
      "cacheConfig": {
        "strategy": "freshness",
        "maxSize": 100,
        "maxAge": "1h",
        "timeout": "10s"
      }
    },
    {
      "name": "api-performance",
      "urls": [
        "/api/technicians/**",
        "/api/jobs/**",
        "/api/assignments/**"
      ],
      "cacheConfig": {
        "strategy": "performance",
        "maxSize": 50,
        "maxAge": "5m"
      }
    },
    {
      "name": "frm-dashboard",
      "urls": [
        "/api/field-resource-management/dashboard/**",
        "/api/field-resource-management/reporting/dashboard"
      ],
      "cacheConfig": {
        "strategy": "performance",
        "maxSize": 10,
        "maxAge": "5m",
        "timeout": "5s"
      }
    },
    {
      "name": "frm-today-jobs",
      "urls": [
        "/api/field-resource-management/jobs/today/**",
        "/api/field-resource-management/technicians/*/schedule/today"
      ],
      "cacheConfig": {
        "strategy": "freshness",
        "maxSize": 20,
        "maxAge": "10m",
        "timeout": "5s"
      }
    },
    {
      "name": "frm-static-data",
      "urls": [
        "/api/field-resource-management/skills/**",
        "/api/field-resource-management/regions/**",
        "/api/field-resource-management/templates/**"
      ],
      "cacheConfig": {
        "strategy": "performance",
        "maxSize": 30,
        "maxAge": "1h"
      }
    }
  ]
}
