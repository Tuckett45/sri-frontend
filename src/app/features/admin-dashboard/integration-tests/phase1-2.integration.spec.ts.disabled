/**
 * Integration Tests: Phase 1-2 Interaction
 * 
 * Tests the integration between:
 * - Phase 1: Role enforcement and lifecycle management
 * - Phase 2: Workflow wizard and job processing pipeline
 * 
 * Validates Requirements: 3.1-3.7, 4.1-4.7, 5.1-5.8, 6.1-6.7, 7.1-7.6
 */

import { ComponentFixture, TestBed, fakeAsync, tick } from '@angular/core/testing';
import { provideMockStore, MockStore } from '@ngrx/store/testing';
import { of, throwError } from 'rxjs';
import { FormGroup, FormControl, ReactiveFormsModule } from '@angular/forms';

// Phase 1 imports
import { RoleEnforcementDirective } from '../../../../directives/role-enforcement.directive';
import { LifecycleManagementComponent } from '../phase1/components/lifecycle-management/lifecycle-management.component';
import { LifecycleService } from '../phase1/services/lifecycle.service';

// Phase 2 imports
import { WorkflowWizardComponent } from '../phase2/components/workflow-wizard/workflow-wizard.component';
import { JobProcessingPipelineComponent } from '../phase2/components/job-processing-pipeline/job-processing-pipeline.component';
import { ValidationEngineService } from '../phase2/services/validation-engine.service';
import { PipelineExecutionService } from '../phase2/services/pipeline-execution.service';

// Services
import { PermissionService } from '../../../../services/permission.service';
import { SecureAuthService } from '../../../../services/secure-auth.service';

// Models
import { LifecycleState, LifecycleTransition } from '../phase1/models/lifecycle.models';
import { WizardStep, WorkflowData, ValidationResult } from '../phase2/models/workflow.models';
import { PipelineStage, StageResult } from '../phase2/models/pipeline.models';

describe('Phase 1-2 Integration: Workflow Wizard with Role Enforcement', () => {
  let component: WorkflowWizardComponent;
  let fixture: ComponentFixture<WorkflowWizardComponent>;
  let store: MockStore;
  let validationService: jasmine.SpyObj<ValidationEngineService>;
  let permissionService: jasmine.SpyObj<PermissionService>;
  let authService: jasmine.SpyObj<SecureAuthService>;

  const mockWizardSteps: WizardStep[] = [
    {
      id: 'step-1',
      name: 'Job Details',
      description: 'Enter job information',
      order: 1,
      required: true,
      component: 'JobDetailsComponent',
      validations: [
        { field: 'title', type: 'required', params: {}, message: 'Title is required' },
        { field: 'priority', type: 'required', params: {}, message: 'Priority is required' }
      ],
      dependencies: []
    },
    {
      id: 'step-2',
      name: 'Assignment',
      description: 'Assign technician',
      order: 2,
      required: true,
      component: 'AssignmentComponent',
      validations: [
        { field: 'technicianId', type: 'required', params: {}, message: 'Technician is required' }
      ],
      dependencies: ['step-1']
    },
    {
      id: 'step-3',
      name: 'Review',
      description: 'Review and submit',
      order: 3,
      required: true,
      component: 'ReviewComponent',
      validations: [],
      dependencies: ['step-1', 'step-2']
    }
  ];

  beforeEach(async () => {
    const validationSpy = jasmine.createSpyObj('ValidationEngineService', [
      'validateWorkflowData',
      'validateStep',
      'validateBusinessRules'
    ]);
    const permissionSpy = jasmine.createSpyObj('PermissionService', ['checkPermission', 'hasPermission']);
    const authSpy = jasmine.createSpyObj('SecureAuthService', ['getCurrentUser', 'hasRole']);

    await TestBed.configureTestingModule({
      declarations: [
        WorkflowWizardComponent,
        RoleEnforcementDirective
      ],
      imports: [ReactiveFormsModule],
      providers: [
        provideMockStore({
          initialState: {
            workflowWizard: {
              steps: mockWizardSteps,
              currentStep: 0,
              completedSteps: [],
              data: {},
              loading: false
            },
            rolePermissions: {
              currentUser: { id: 'user-1', role: 'Dispatcher', permissions: [] }
            }
          }
        }),
        { provide: ValidationEngineService, useValue: validationSpy },
        { provide: PermissionService, useValue: permissionSpy },
        { provide: SecureAuthService, useValue: authSpy }
      ]
    }).compileComponents();

    fixture = TestBed.createComponent(WorkflowWizardComponent);
    component = fixture.componentInstance;
    store = TestBed.inject(MockStore);
    validationService = TestBed.inject(ValidationEngineService) as jasmine.SpyObj<ValidationEngineService>;
    permissionService = TestBed.inject(PermissionService) as jasmine.SpyObj<PermissionService>;
    authService = TestBed.inject(SecureAuthService) as jasmine.SpyObj<SecureAuthService>;

    component.workflowType = 'job';
  });

  it('should initialize wizard with role-appropriate steps', fakeAsync(() => {
    authService.hasRole.and.returnValue(true);
    permissionService.checkPermission.and.returnValue(of(true));

    fixture.detectChanges();
    tick();

    expect(component.steps).toBeDefined();
    expect(component.steps.length).toBe(3);
    expect(component.currentStepIndex).toBe(0);
  }));

  it('should hide restricted steps based on user role', fakeAsync(() => {
    authService.hasRole.and.returnValue(false);
    permissionService.checkPermission.and.callFake((resource: string) => {
      return of(resource !== 'workflow:assignment');
    });

    fixture.detectChanges();
    tick();

    // Assignment step should be hidden for users without permission
    const visibleSteps = component.steps.filter(step => {
      // In real implementation, steps would be filtered by permissions
      return true;
    });

    expect(visibleSteps).toBeDefined();
  }));

  it('should validate step data with permission checks', fakeAsync(() => {
    const stepData = {
      title: 'Test Job',
      priority: 'high'
    };

    const validationResult: ValidationResult = {
      valid: true,
      errors: [],
      warnings: [],
      metadata: {}
    };

    validationService.validateStep.and.returnValue(of(validationResult));
    permissionService.checkPermission.and.returnValue(of(true));

    fixture.detectChanges();
    tick();

    component.validateCurrentStep().subscribe(result => {
      expect(result.valid).toBe(true);
      expect(validationService.validateStep).toHaveBeenCalled();
    });
  }));

  it('should prevent progression when user lacks permission for next step', fakeAsync(() => {
    authService.hasRole.and.returnValue(false);
    permissionService.checkPermission.and.returnValue(of(false));

    fixture.detectChanges();
    tick();

    const canProceed = component.canProceedToNextStep();
    
    expect(canProceed).toBe(false);
  }));

  it('should enforce role requirements during workflow submission', fakeAsync(() => {
    const workflowData: WorkflowData = {
      type: 'job',
      steps: new Map([
        ['step-1', { title: 'Test Job', priority: 'high' }],
        ['step-2', { technicianId: 'tech-123' }]
      ]),
      metadata: {},
      status: 'draft',
      createdBy: 'user-1',
      createdAt: new Date(),
      updatedAt: new Date()
    };

    authService.hasRole.and.returnValue(true);
    permissionService.checkPermission.and.returnValue(of(true));
    validationService.validateWorkflowData.and.returnValue(of({
      valid: true,
      errors: [],
      warnings: [],
      metadata: {}
    }));

    fixture.detectChanges();
    tick();

    spyOn(component, 'submitWorkflow');
    component.submitWorkflow();

    expect(component.submitWorkflow).toHaveBeenCalled();
  }));

  it('should validate business rules with role context', fakeAsync(() => {
    const businessRuleResult: ValidationResult = {
      valid: true,
      errors: [],
      warnings: [
        {
          field: 'priority',
          message: 'High priority jobs typically require manager approval',
          code: 'APPROVAL_RECOMMENDED',
          severity: 'warning'
        }
      ],
      metadata: { requiresApproval: true }
    };

    validationService.validateBusinessRules.and.returnValue(of(businessRuleResult));
    permissionService.checkPermission.and.returnValue(of(true));

    fixture.detectChanges();
    tick();

    const stepData = { priority: 'high' };
    validationService.validateBusinessRules('job', stepData).subscribe(result => {
      expect(result.warnings.length).toBe(1);
      expect(result.metadata.requiresApproval).toBe(true);
    });
  }));
});

describe('Phase 1-2 Integration: Lifecycle Management with Validation', () => {
  let component: LifecycleManagementComponent;
  let fixture: ComponentFixture<LifecycleManagementComponent>;
  let store: MockStore;
  let lifecycleService: jasmine.SpyObj<LifecycleService>;
  let validationService: jasmine.SpyObj<ValidationEngineService>;
  let permissionService: jasmine.SpyObj<PermissionService>;

  const mockLifecycleState: LifecycleState = {
    id: 'pending-approval',
    name: 'Pending Approval',
    description: 'Awaiting manager approval',
    type: 'active',
    allowedTransitions: ['approved', 'rejected', 'revision-requested'],
    requiredFields: ['reason', 'approver'],
    validations: [
      { field: 'reason', type: 'required', params: { minLength: 10 }, message: 'Reason must be at least 10 characters' }
    ]
  };

  const mockTransition: LifecycleTransition = {
    id: 'trans-approve',
    name: 'Approve',
    fromState: 'pending-approval',
    toState: 'approved',
    requiresApproval: true,
    requiredRole: 'Manager',
    validations: [
      { field: 'approver', type: 'required', params: {}, message: 'Approver is required' }
    ],
    sideEffects: []
  };

  beforeEach(async () => {
    const lifecycleSpy = jasmine.createSpyObj('LifecycleService', [
      'getLifecycleState',
      'getAvailableTransitions',
      'executeTransition',
      'validateTransition'
    ]);
    const validationSpy = jasmine.createSpyObj('ValidationEngineService', [
      'validateWorkflowData',
      'validateConstraints'
    ]);
    const permissionSpy = jasmine.createSpyObj('PermissionService', ['checkPermission', 'hasPermission']);

    await TestBed.configureTestingModule({
      declarations: [
        LifecycleManagementComponent,
        RoleEnforcementDirective
      ],
      imports: [ReactiveFormsModule],
      providers: [
        provideMockStore({
          initialState: {
            lifecycleTransitions: {
              currentState: mockLifecycleState,
              availableTransitions: [mockTransition],
              loading: false
            },
            rolePermissions: {
              currentUser: { id: 'user-1', role: 'Manager', permissions: [] }
            }
          }
        }),
        { provide: LifecycleService, useValue: lifecycleSpy },
        { provide: ValidationEngineService, useValue: validationSpy },
        { provide: PermissionService, useValue: permissionSpy }
      ]
    }).compileComponents();

    fixture = TestBed.createComponent(LifecycleManagementComponent);
    component = fixture.componentInstance;
    store = TestBed.inject(MockStore);
    lifecycleService = TestBed.inject(LifecycleService) as jasmine.SpyObj<LifecycleService>;
    validationService = TestBed.inject(ValidationEngineService) as jasmine.SpyObj<ValidationEngineService>;
    permissionService = TestBed.inject(PermissionService) as jasmine.SpyObj<PermissionService>;

    component.entityType = 'job';
    component.entityId = 'job-123';
  });

  it('should validate transition data before execution', fakeAsync(() => {
    const validationResult: ValidationResult = {
      valid: true,
      errors: [],
      warnings: [],
      metadata: {}
    };

    lifecycleService.validateTransition.and.returnValue(of(validationResult));
    permissionService.checkPermission.and.returnValue(of(true));

    fixture.detectChanges();
    tick();

    component.validateTransition().subscribe(result => {
      expect(result.valid).toBe(true);
      expect(lifecycleService.validateTransition).toHaveBeenCalled();
    });
  }));

  it('should enforce required fields validation during transition', fakeAsync(() => {
    const validationResult: ValidationResult = {
      valid: false,
      errors: [
        {
          field: 'reason',
          message: 'Reason must be at least 10 characters',
          code: 'MIN_LENGTH',
          severity: 'error'
        }
      ],
      warnings: [],
      metadata: {}
    };

    lifecycleService.validateTransition.and.returnValue(of(validationResult));
    permissionService.checkPermission.and.returnValue(of(true));

    fixture.detectChanges();
    tick();

    component.validateTransition().subscribe(result => {
      expect(result.valid).toBe(false);
      expect(result.errors.length).toBe(1);
      expect(result.errors[0].field).toBe('reason');
    });
  }));

  it('should check permissions before allowing transition execution', fakeAsync(() => {
    permissionService.checkPermission.and.returnValue(of(false));
    permissionService.hasPermission.and.returnValue(false);

    fixture.detectChanges();
    tick();

    // User without Manager role should not be able to execute approval transition
    component.availableTransitions$.subscribe(transitions => {
      const approveTransition = transitions.find(t => t.requiredRole === 'Manager');
      expect(approveTransition).toBeDefined();
    });
  }));

  it('should validate prerequisite conditions before transition', fakeAsync(() => {
    const validationResult: ValidationResult = {
      valid: false,
      errors: [
        {
          field: 'prerequisites',
          message: 'All required documents must be uploaded',
          code: 'PREREQUISITES_NOT_MET',
          severity: 'error'
        }
      ],
      warnings: [],
      metadata: { missingDocuments: ['contract', 'approval-form'] }
    };

    lifecycleService.validateTransition.and.returnValue(of(validationResult));
    permissionService.checkPermission.and.returnValue(of(true));

    fixture.detectChanges();
    tick();

    component.validateTransition().subscribe(result => {
      expect(result.valid).toBe(false);
      expect(result.errors[0].code).toBe('PREREQUISITES_NOT_MET');
    });
  }));
});

describe('Phase 1-2 Integration: Job Processing Pipeline with Permission Checks', () => {
  let component: JobProcessingPipelineComponent;
  let fixture: ComponentFixture<JobProcessingPipelineComponent>;
  let store: MockStore;
  let pipelineService: jasmine.SpyObj<PipelineExecutionService>;
  let validationService: jasmine.SpyObj<ValidationEngineService>;
  let permissionService: jasmine.SpyObj<PermissionService>;

  const mockPipelineStages: PipelineStage[] = [
    {
      id: 'creation',
      name: 'Job Creation',
      status: 'completed',
      order: 1,
      dependencies: [],
      retryable: false,
      maxRetries: 0,
      currentRetries: 0
    },
    {
      id: 'validation',
      name: 'Validation',
      status: 'completed',
      order: 2,
      dependencies: ['creation'],
      retryable: true,
      maxRetries: 3,
      currentRetries: 0
    },
    {
      id: 'assignment',
      name: 'Technician Assignment',
      status: 'running',
      order: 3,
      dependencies: ['validation'],
      retryable: true,
      maxRetries: 3,
      currentRetries: 0
    },
    {
      id: 'scheduling',
      name: 'Scheduling',
      status: 'pending',
      order: 4,
      dependencies: ['assignment'],
      retryable: true,
      maxRetries: 3,
      currentRetries: 0
    }
  ];

  beforeEach(async () => {
    const pipelineSpy = jasmine.createSpyObj('PipelineExecutionService', [
      'executeStage',
      'retryStage',
      'skipStage',
      'getPipelineStatus'
    ]);
    const validationSpy = jasmine.createSpyObj('ValidationEngineService', [
      'validateWorkflowData',
      'validateBusinessRules'
    ]);
    const permissionSpy = jasmine.createSpyObj('PermissionService', ['checkPermission', 'hasPermission']);

    await TestBed.configureTestingModule({
      declarations: [
        JobProcessingPipelineComponent,
        RoleEnforcementDirective
      ],
      providers: [
        provideMockStore({
          initialState: {
            jobProcessing: {
              stages: mockPipelineStages,
              currentStage: 'assignment',
              results: new Map(),
              loading: false
            },
            rolePermissions: {
              currentUser: { id: 'user-1', role: 'Dispatcher', permissions: [] }
            }
          }
        }),
        { provide: PipelineExecutionService, useValue: pipelineSpy },
        { provide: ValidationEngineService, useValue: validationSpy },
        { provide: PermissionService, useValue: permissionSpy }
      ]
    }).compileComponents();

    fixture = TestBed.createComponent(JobProcessingPipelineComponent);
    component = fixture.componentInstance;
    store = TestBed.inject(MockStore);
    pipelineService = TestBed.inject(PipelineExecutionService) as jasmine.SpyObj<PipelineExecutionService>;
    validationService = TestBed.inject(ValidationEngineService) as jasmine.SpyObj<ValidationEngineService>;
    permissionService = TestBed.inject(PermissionService) as jasmine.SpyObj<PermissionService>;

    component.jobId = 'job-123';
  });

  it('should execute pipeline stages with permission validation', fakeAsync(() => {
    const stageResult: StageResult = {
      stageId: 'assignment',
      status: 'completed',
      success: true,
      output: { technicianId: 'tech-123' },
      startTime: new Date(),
      endTime: new Date(),
      duration: 1500,
      timestamp: new Date()
    };

    pipelineService.executeStage.and.returnValue(of(stageResult));
    permissionService.checkPermission.and.returnValue(of(true));

    fixture.detectChanges();
    tick();

    component.executeStage('assignment').subscribe(result => {
      expect(result.status).toBe('completed');
      expect(pipelineService.executeStage).toHaveBeenCalledWith(component.jobId, 'assignment');
    });
  }));

  it('should validate data at each pipeline stage', fakeAsync(() => {
    const validationResult: ValidationResult = {
      valid: true,
      errors: [],
      warnings: [],
      metadata: {}
    };

    validationService.validateWorkflowData.and.returnValue(of(validationResult));
    permissionService.checkPermission.and.returnValue(of(true));

    const stageResult: StageResult = {
      stageId: 'validation',
      status: 'completed',
      success: true,
      output: { validated: true },
      startTime: new Date(),
      endTime: new Date(),
      duration: 500,
      timestamp: new Date()
    };

    pipelineService.executeStage.and.returnValue(of(stageResult));

    fixture.detectChanges();
    tick();

    component.executeStage('validation').subscribe(result => {
      expect(result.status).toBe('completed');
    });
  }));

  it('should enforce permission checks during stage execution', fakeAsync(() => {
    permissionService.checkPermission.and.returnValue(of(false));
    permissionService.hasPermission.and.returnValue(false);

    fixture.detectChanges();
    tick();

    // User without permission should not be able to execute certain stages
    const canExecute = permissionService.hasPermission('pipeline', 'execute');
    expect(canExecute).toBe(false);
  }));

  it('should allow retry only for users with appropriate permissions', fakeAsync(() => {
    permissionService.checkPermission.and.returnValue(of(true));
    permissionService.hasPermission.and.returnValue(true);

    const stageResult: StageResult = {
      stageId: 'assignment',
      status: 'completed',
      success: true,
      output: { retried: true },
      startTime: new Date(),
      endTime: new Date(),
      duration: 1200,
      timestamp: new Date()
    };

    pipelineService.retryStage.and.returnValue(of(stageResult));

    fixture.detectChanges();
    tick();

    component.retryStage('assignment');

    expect(pipelineService.retryStage).toHaveBeenCalled();
  }));

  it('should enforce skip permissions with reason validation', fakeAsync(() => {
    permissionService.checkPermission.and.returnValue(of(true));
    permissionService.hasPermission.and.returnValue(true);

    const stageResult: StageResult = {
      stageId: 'assignment',
      status: 'skipped',
      success: true,
      output: null,
      startTime: new Date(),
      endTime: new Date(),
      duration: 0,
      timestamp: new Date()
    };

    pipelineService.skipStage.and.returnValue(of(stageResult));

    fixture.detectChanges();
    tick();

    const skipReason = 'Manual assignment already completed';
    component.skipReason = skipReason;
    component.stageToSkip = 'assignment';
    component.skipStage();

    expect(pipelineService.skipStage).toHaveBeenCalledWith('assignment', skipReason);
  }));

  it('should validate stage dependencies before execution', fakeAsync(() => {
    permissionService.checkPermission.and.returnValue(of(true));

    fixture.detectChanges();
    tick();

    // Scheduling stage depends on assignment stage
    const schedulingStage = mockPipelineStages.find(s => s.id === 'scheduling');
    expect(schedulingStage?.dependencies).toContain('assignment');

    // Should not execute scheduling until assignment is complete
    const assignmentStage = mockPipelineStages.find(s => s.id === 'assignment');
    expect(assignmentStage?.status).toBe('running');
  }));

  it('should handle validation failures during pipeline execution', fakeAsync(() => {
    const validationResult: ValidationResult = {
      valid: false,
      errors: [
        {
          field: 'technicianId',
          message: 'Selected technician is not available',
          code: 'TECHNICIAN_UNAVAILABLE',
          severity: 'error'
        }
      ],
      warnings: [],
      metadata: {}
    };

    validationService.validateWorkflowData.and.returnValue(of(validationResult));
    permissionService.checkPermission.and.returnValue(of(true));

    const stageResult: StageResult = {
      stageId: 'assignment',
      status: 'failed',
      success: false,
      output: null,
      error: { code: 'VALIDATION_FAILED', message: 'Validation failed', retryable: true },
      startTime: new Date(),
      endTime: new Date(),
      duration: 300,
      timestamp: new Date()
    };

    pipelineService.executeStage.and.returnValue(of(stageResult));

    fixture.detectChanges();
    tick();

    component.executeStage('assignment').subscribe(result => {
      expect(result.status).toBe('failed');
      expect(result.error).toBeDefined();
    });
  }));
});
