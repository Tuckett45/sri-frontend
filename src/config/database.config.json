{
    "$schema": "https://github.com/Azure/data-api-builder/releases/latest/download/dab.draft.schema.json",
    "data-source": {
      "database-type": "mssql",
      "options": {
        "set-session-context": false 
      },
      "connection-string": "Server=tcp:sri-database-prod.database.windows.net,1433;Initial Catalog=sri-prod;Encrypt=True;TrustServerCertificate=False;Connection Timeout=30;"
    },
    "runtime": {
      "rest": {
        "enabled": true,
        "path": "/rest"
      },
      "graphql": {
        "allow-introspection": true,
        "enabled": true,
        "path": "/graphql"
      },
      "host": {
        "mode": "production",
        "cors": {
          "origins": ["https://ark-sri.com"],
          "allow-credentials": false
        },
        "authentication": {
          "provider": "StaticWebApps"
        }
      }
    },
    "entities": {
      "PunchListImages": {
        "source": "dbo.PunchListImages",
        "permissions": [
          {
            "actions": ["create", "read", "update", "delete"],
            "role": "anonymous"
          }
        ]
      },
      "PreliminaryPunchList": {
        "source": "dbo.PreliminaryPunchList",
        "permissions": [
          {
            "actions": ["create", "read", "update", "delete"],
            "role": "anonymous"
          }
        ]
      },
      "PasswordResetTokens": {
        "source": "dbo.PasswordResetTokens",
        "permissions": [
          {
            "actions": ["create", "read", "update", "delete"],
            "role": "anonymous"
          }
        ]
      },
      "IssueArea": {
        "source": "dbo.IssueArea",
        "permissions": [
          {
            "actions": ["create", "read", "update", "delete"],
            "role": "anonymous"
          }
        ]
      },
      "Users": {
        "source": "dbo.Users",
        "permissions": [
          {
            "actions": ["create", "read", "update", "delete"],
            "role": "anonymous"
          }
        ]
      }
    },
    "api": {
      "csharpApi": {
        "base-url": "https://sri-backend-h7hah8eefngwe7ar.westus2-01.azurewebsites.net"
      }
    }
  }